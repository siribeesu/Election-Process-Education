{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "set NODE_ENV=development && npx pnpm run build && npx pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --env-file=../../.env ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/integrations-gemini-ai": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "express": "^5",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@google/genai": "^1.51.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.5"
  }
}
